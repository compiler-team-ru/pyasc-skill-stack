__pycache__/
*.pyc
.codex
.eval-history/

# Agent-generated kernel outputs (test artifacts from opencode runs).
# The single tracked kernel is `add/` (no dtype suffix); every directory
# named after a typed kernel (e.g. add_f16/, reduce_sum_f32/, abs_float32/)
# is a transient agent scratch dir and must stay untracked.
teams/pyasc-kernel-dev-team/kernels/abs_f16/
teams/pyasc-kernel-dev-team/kernels/abs_f32/
teams/pyasc-kernel-dev-team/kernels/abs_float32/
teams/pyasc-kernel-dev-team/kernels/add_f16/
teams/pyasc-kernel-dev-team/kernels/gelu_f16/
teams/pyasc-kernel-dev-team/kernels/gelu_f32/
teams/pyasc-kernel-dev-team/kernels/leaky_relu_f16/
teams/pyasc-kernel-dev-team/kernels/matmul_f16/
teams/pyasc-kernel-dev-team/kernels/neg_f16/
teams/pyasc-kernel-dev-team/kernels/reduce_sum_f16/
teams/pyasc-kernel-dev-team/kernels/reduce_sum_f32/
teams/pyasc-kernel-dev-team/kernels/rms_norm_f16/
teams/pyasc-kernel-dev-team/kernels/rms_norm_f32/
teams/pyasc-kernel-dev-team/kernels/softmax_f16/
teams/pyasc-kernel-dev-team/kernels/sub_f16/
teams/pyasc-kernel-dev-team/kernels/vadd_f32_1024/

# Matrix-run orchestrator logs (forensic records; kept on disk only).
run-matrix-log-*.csv

# Generated dashboard output
_site/

# CI-only generative kernel archive (uploaded as artifact, not committed)
generative-archive/

# Stage B/C kernel archive — keep kernels + review docs for forensics,
# but exclude the high-noise duplicates (agent stdout log, copy of
# AGENTS.md / opencode.json that live in the repo already).
evidence/runtime-archive/**/agent-output.txt
evidence/runtime-archive/**/opencode.json
evidence/runtime-archive/**/AGENTS.md

# Large binary files in Docker overlay (built locally, not tracked).
# Per-arch subdirectories (x86_64/, aarch64/) keep their host-built .so
# locally; both are picked up by docker/Dockerfile.overlay at build time.
docker/pyasc-overlay/asc_C/*.so
docker/pyasc-overlay/asc_C/**/*.so
